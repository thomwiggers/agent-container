{
  "name": "agent-container",
  "dockerComposeFile": "compose.yaml",
  "service": "agent",
  "workspaceFolder": "/workspace",
  "shutdownAction": "stopCompose",
  "features": {
      "ghcr.io/devcontainers/features/github-cli:1": {}
  },
  "mounts": [
    "source=${localEnv:HOME}/.claude/settings.json,target=/home/vscode/.claude-host/settings.json,type=bind,readonly",
    "source=${localEnv:HOME}/.claude/CLAUDE.md,target=/home/vscode/.claude-host/CLAUDE.md,type=bind,readonly",
    "source=${localEnv:HOME}/.claude/plugins,target=/home/vscode/.claude-host/plugins,type=bind,readonly",
    "source=${localEnv:HOME}/.claude/skills,target=/home/vscode/.claude-host/skills,type=bind,readonly",
    "source=${localEnv:HOME}/.claude/cache,target=/home/vscode/.claude-host/cache,type=bind,readonly",
    "source=${localEnv:HOME}/.claude/ide,target=/home/vscode/.claude-host/ide,type=bind,readonly",
    "source=${localEnv:HOME}/.gitconfig,target=/home/vscode/.gitconfig,type=bind,readonly",
    "source=${localEnv:HOME}/.zshrc,target=/home/vscode/.zshrc.host,type=bind,readonly",
    "source=claude-code-bashhistory-${devcontainerId},target=/commandhistory,type=volume",
    "source=claude-code-config-${devcontainerId},target=/home/vscode/.claude,type=volume",
    "source=claude-code-gh-${devcontainerId},target=/home/vscode/.config/gh,type=volume",
    "source=${localWorkspaceFolder}/.devcontainer,target=${containerWorkspaceFolder}/.devcontainer,type=bind,readonly",
    "source=${localWorkspaceFolder},target=/workspace,type=bind",
    "source=${localEnv:SSH_AUTH_SOCK:-/run/host-services/ssh-auth.sock},target=/ssh-agent,type=bind"
  ],
  "containerEnv": {
    "CLAUDE_CODE_OAUTH_TOKEN": "${localEnv:CLAUDE_CODE_OAUTH_TOKEN}",
    "HISTFILE": "/commandhistory/.zsh_history",
    "SSH_AUTH_SOCK": "/ssh-agent"
  },
  "postCreateCommand": "bash -c 'for p in \"${containerWorkspaceFolder}/.devcontainer/scripts/postCreate.sh\" \"${containerWorkspaceFolder}/.devcontainer-local/postCreate.sh\"; do [ -f \"$p\" ] && exec bash \"$p\"; done'",
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "zsh",
        "claudeCode.allowDangerouslySkipPermissions": true
      },
      "extensions": [
        "anthropic.claude-code"
      ]
    }
  },
  "remoteUser": "vscode"
}
